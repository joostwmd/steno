{
  "name": "steno-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n server,ui -c blue,green \"pnpm --filter @steno/server dev\" \"pnpm --filter @steno/ui dev\"",
    "test": "pnpm --filter @steno/core test",
    "db:generate": "pnpm --filter @steno/db db:generate",
    "db:push": "pnpm --filter @steno/db db:push",
    "steno:ingest": "steno ingest",
    "steno:dev": "STENO_DEV_THROW_ERROR=1 steno dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "steno": "workspace:*",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0"
}
