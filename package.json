{
  "name": "steno-monorepo",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/joostwmd/steno.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n server,ui -c blue,green \"pnpm --filter @steno/server dev\" \"pnpm --filter @steno/ui dev\"",
    "test": "pnpm --filter @steno/core test && pnpm --filter @steno/api test",
    "db:generate": "pnpm --filter @steno/db db:generate",
    "db:push": "pnpm --filter @steno/db db:push",
    "steno:ingest": "steno ingest",
    "steno:dev": "steno dev",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@joostwmd/steno": "workspace:*",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0"
}
