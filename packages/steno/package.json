{
  "name": "@joostwmd/steno",
  "version": "0.1.0",
  "description": "CLI for Cursor hook telemetry — NDJSON log, SQLite, and bundled web UI",
  "private": false,
  "type": "module",
  "bin": {
    "steno": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:deps && node build.mjs",
    "build:deps": "pnpm --filter @steno/core build && pnpm --filter @steno/db build && pnpm --filter @steno/api build",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "cursor",
    "telemetry",
    "hooks",
    "ndjson",
    "sqlite",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joostwmd/steno.git",
    "directory": "packages/steno"
  },
  "bugs": {
    "url": "https://github.com/joostwmd/steno/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@trpc/server": "^11.0.1",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jiti": "^2.4.2",
    "js-tiktoken": "^1.0.21",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/prompts": "^2.4.9",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
